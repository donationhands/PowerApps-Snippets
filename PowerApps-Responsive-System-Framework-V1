
/*
  ══════════════════════════════════════════════════════════════════
  COLOR CONVERSION SUITE — Dynamic Runtime Converters
  ══════════════════════════════════════════════════════════════════
*/

// ── HEX — Color object → "#RRGGBB" ────────────────────────────
fxColor2Hex(ColorValue: Color): Text = 
    Match(
        JSON(ColorValue, JSONFormat.IgnoreUnsupportedTypes),
        "#[a-fA-F0-9]{6}"
    ).FullMatch;


// ── Channel Extraction — Color object → individual R, G, B ─────
fxColorRed(ColorValue: Color): Number = 
    With(
        { hex: fxColor2Hex(ColorValue) },
        Hex2Dec(Mid(hex, 2, 2))
    );

fxColorGreen(ColorValue: Color): Number = 
    With(
        { hex: fxColor2Hex(ColorValue) },
        Hex2Dec(Mid(hex, 4, 2))
    );

fxColorBlue(ColorValue: Color): Number = 
    With(
        { hex: fxColor2Hex(ColorValue) },
        Hex2Dec(Mid(hex, 6, 2))
    );


// ── RGB CSS String — Color object → "rgb(R,G,B)" ──────────────
fxColor2Rgb(ColorValue: Color): Text = 
    With(
        { hex: fxColor2Hex(ColorValue) },
        "rgb(" &
            Hex2Dec(Mid(hex, 2, 2)) & "," &
            Hex2Dec(Mid(hex, 4, 2)) & "," &
            Hex2Dec(Mid(hex, 6, 2)) &
        ")"
    );


// ── RGBA CSS String — Color object → "rgba(R,G,B,A)" ──────────
fxColor2Rgba(ColorValue: Color, Alpha: Number): Text = 
    With(
        { hex: fxColor2Hex(ColorValue) },
        "rgba(" &
            Hex2Dec(Mid(hex, 2, 2)) & "," &
            Hex2Dec(Mid(hex, 4, 2)) & "," &
            Hex2Dec(Mid(hex, 6, 2)) & "," &
            Text(Alpha) &
        ")"
    );


// ── Opacity Helper — Apply opacity to any Color object ─────────
fxColorWithOpacity(ColorValue: Color, Opacity: Number): Text = fxColor2Rgba(ColorValue, Opacity);

