/*
  ══════════════════════════════════════════════════════════════════
  USAGE EXAMPLES
  ══════════════════════════════════════════════════════════════════

  ── Basic: Image control with theme color ───────────────────────

  Image.Image  = fxIcon(gblAppIcons.Search, AppTheme.BrandPrimary.Css)
  Image.Width  = fxIconSize(App.Width, 2)
  Image.Height = fxIconSize(App.Width, 2)


  ── Dynamic color from Color object ─────────────────────────────

  Image.Image = fxIconThemed(gblAppIcons.Warning, AppTheme.StatusWarning.Color)


  ── With embedded size override ─────────────────────────────────

  Image.Image = fxIconSized(gblAppIcons.Home, AppTheme.BrandPrimary.Css, 32)


  ── Conditional color based on state ────────────────────────────

  Image.Image = fxIcon(
      gblAppIcons.Check,
      If(ThisItem.IsComplete, AppTheme.StatusSuccess.Css, AppTheme.TextTertiary.Css)
  )


  ── In a gallery with status icons ──────────────────────────────

  Image.Image = fxIcon(
      Switch(
          ThisItem.Status,
          "Complete", gblAppIcons.Check,
          "Warning",  gblAppIcons.Warning,
          "Error",    gblAppIcons.Error,
          gblAppIcons.Info
      ),
      Switch(
          ThisItem.Status,
          "Complete", AppTheme.StatusSuccess.Css,
          "Warning",  AppTheme.StatusWarning.Css,
          "Error",    AppTheme.StatusError.Css,
          AppTheme.StatusInfo.Css
      )
  )


  ── Sidebar nav with active state ───────────────────────────────

  Image.Image = fxIcon(
      gblAppIcons.Home,
      If(
          gblActivePage = "Home",
          AppTheme.BrandAccent.Css,
          "#FFFFFF"
      )
  )

  ── Inside HtmlText (embed directly as img src) ────────────────

  HtmlText.HtmlText = 
      "<div style='display:flex; align-items:center; gap:" & fxSpacing(App.Width, 2) & "px;'>" &
          "<img src=""" & fxIcon(gblAppIcons.Search, AppTheme.TextSecondary.Css) & """ 
              width='" & fxIconSize(App.Width, 1) & "' 
              height='" & fxIconSize(App.Width, 1) & "' />" &
          "<span style='" & fxCssBodyStyle & "'>Search results</span>" &
      "</div>"

*/
